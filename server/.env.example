# ─────────────────────────────────────────
# Server / Backend environment variables
# ─────────────────────────────────────────

PORT=5001
MONGODB_URI=mongodb://127.0.0.1:27017/resumeiq
JWT_SECRET=replace_with_a_long_random_secret

# xAI/Grok API key
GROK_API_KEY=your_xai_api_key_here

# Optional. Defaults to grok-4.3
GROK_MODEL=grok-4.3

# Frontend URL for CORS (your Vercel URL in production)
FRONTEND_URL=http://localhost:5173
